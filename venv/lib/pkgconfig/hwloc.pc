exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: hwloc
Description: Hardware locality detection and management library
Version: 2.12.1
Requires.private: libxml-2.0 
Cflags: -I${includedir}
